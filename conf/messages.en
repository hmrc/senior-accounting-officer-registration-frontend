registration.dashboard.row.status.cannotStartYet = Cannot start yet
registration.dashboard.row.status.completed = Completed

registration.dashboard.submit = Submit your registration

registration.complete.title = SAO Registration Confirmation
registration.complete.heading = Registration complete
registration.complete.referenceNumberPrefix = Your reference number
registration.complete.p1 = We’ve sent a confirmation email to all the contacts you gave during registration.
registration.complete.p2 = if you want to keep a paper record of your registration.
registration.complete.h2 = What happens next
registration.complete.p3 = You can now log in to submit a notification and certificate.
registration.complete.print = Print this page
registration.complete.continue = Continue

contactDetailsGuidance.title = Contact details
contactDetailsGuidance.caption = Contact details
contactDetailsGuidance.heading = Provide contact details for the company
contactDetailsGuidance.p1 = You need to give us the contact details of the person or team responsible for submitting the company’s notification and certificate.
contactDetailsGuidance.p2 = We’ll use these details to:
contactDetailsGuidance.b1 = contact the right person if we have questions about the company’s tax accounting arrangements
contactDetailsGuidance.b2 = send confirmation when the notification and certificate have been submitted
contactDetailsGuidance.p3 = You can provide details for up to 2 contacts. For each contact, you’ll need to enter their full name and email address.

contact.first.caption = First contact details
contact.second.caption = Second contact details

contactName.title.first  = First contact details
contactName.title.second = Second contact details
contactName.title.third  = Third contact details
contactName.heading = What is the name of the person or team to keep on record?
contactName.hint = For example, ‘Ashley Smith or Tax team’.
contactName.checkYourAnswersLabel = Full name
contactName.error.required = Enter the name of the person or team who can deal with enquiries about the company’s tax accounting arrangements.
contactName.error.length = Name of the person or team must be 50 characters or less
contactName.change.first.hidden = change the full name
contactName.error.invalidChars = The name you enter must not include the following characters <, >, " or &
contactName.change.second.hidden = change the full name

contactEmail.title.first  = First contact details
contactEmail.title.second = Second contact details
contactEmail.title.third  = Third contact details
contactEmail.heading = What is their email address?
contactEmail.hint = We’ll only use this to contact them about the company’s submission.
contactEmail.checkYourAnswersLabel = Email address
contactEmail.error.required = Enter the email address of the person or team
contactEmail.error.length = The email address you enter must be 50 characters or less
contactEmail.error.format = Enter an email address in the correct format, like name@example.com
contactEmail.change.first.hidden = change the email address
contactEmail.change.second.hidden = change the email address

contactHaveYouAddedAll.title = First contact details
contactHaveYouAddedAll.heading = Have you added all the contacts you need?
contactHaveYouAddedAll.hint = Provide more than one contact if possible, in case we do not get a response from the primary contact. You can add up to two contact details.
contactHaveYouAddedAll.yes = Yes
contactHaveYouAddedAll.no = No, add another contact
